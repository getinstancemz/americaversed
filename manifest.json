{
  "manifest_version": 2,
  "name": "America Versed",
  "version": "1.0",

  "description": "Text blocks that contain triggering content and replaces them with poetry.",

  "browser_specific_settings": {
    "gecko": {
      "id": "americaversed@getinstance.com"
    }
  },

  "icons": {
    "128": "imgs/americaversed.svg",
    "16": "imgs/americaversed.svg",
    "32": "imgs/americaversed.svg",
    "48": "imgs/americaversed.svg",
    "64": "imgs/americaversed.svg",
    "96": "imgs/americaversed.svg"
  },

  "browser_action": {
    "default_icon": "imgs/americaversed.svg",
    "default_title": "America Versed",
    "default_popup": "popup/americaversed-prefs.html"
  },
  "permissions": [ "<all_urls>", "storage", "webRequest", "contextMenus" ],
  "web_accessible_resources": [
    "americaversed-poem.html",
    "americaversed.css"
  ],
  "options_ui": {
    "page": "settings/dashboard.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["americaversed.js"],
      "css": ["americaversed.css"]
    }
  ],
  "background": {
      "scripts": ["background.js"]
  }
}

